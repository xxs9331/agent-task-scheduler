{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.invalid/scheduler/publish-input.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["input_schema_version", "project_id", "operation", "tasks"],
  "properties": {
    "input_schema_version": {"type": "integer", "const": 1},
    "project_id": {"type": "string", "minLength": 1},
    "operation": {"enum": ["create", "update"]},
    "tasks": {"type": "array", "minItems": 1}
  },
  "oneOf": [
    {"properties": {"operation": {"const": "create"}, "tasks": {"items": {"$ref": "#/$defs/create_task"}}}},
    {"properties": {"operation": {"const": "update"}, "tasks": {"items": {"$ref": "#/$defs/update_task"}}}}
  ],
  "$defs": {
    "create_task": {"type": "object", "additionalProperties": false, "required": ["task_id", "agent_type", "depends_on", "conflict_domain", "preferred_worker", "worker_prompt"], "properties": {"task_id": {"type": "string", "minLength": 1}, "agent_type": {"type": "string", "minLength": 1}, "depends_on": {"type": "array", "items": {"type": "string"}}, "conflict_domain": {"type": "string", "minLength": 1}, "preferred_worker": {"type": "string", "minLength": 1}, "worker_prompt": {"type": "object"}, "title": {"type": "string"}, "description": {"type": "string"}, "metadata": {"type": "object"}}},
    "update_task": {"type": "object", "additionalProperties": false, "required": ["task_id", "patch"], "properties": {"task_id": {"type": "string", "minLength": 1}, "patch": {"$ref": "#/$defs/update_patch"}}},
    "update_patch": {"type": "object", "additionalProperties": false, "minProperties": 1, "properties": {"agent_type": {"type": "string", "minLength": 1}, "depends_on": {"type": "array", "items": {"type": "string"}}, "conflict_domain": {"type": "string", "minLength": 1}, "preferred_worker": {"type": "string", "minLength": 1}, "worker_prompt": {"type": "object"}, "title": {"type": "string"}, "description": {"type": "string"}, "metadata": {"type": "object"}}}
  }
}
