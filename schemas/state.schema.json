{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scheduler/state.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project_id", "tasks", "publish_history"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "project_id": {"type": "string", "minLength": 1},
    "tasks": {"type": "object", "additionalProperties": {"$ref": "#/$defs/task"}},
    "task_order": {"type": "array", "items": {"type": "string"}},
    "publish_history": {"type": "array", "items": {"$ref": "#/$defs/history"}},
    "review_decisions": {"type": "array", "items": {"$ref": "#/$defs/review_decision"}},
    "staff_model": {"$ref": "#/$defs/staff_model"}
  },
  "$defs": {
    "task": {"type": "object", "required": ["task_id", "status", "agent_type", "depends_on", "conflict_domain", "preferred_worker", "worker_prompt", "created_at"], "properties": {"task_id": {"type": "string"}, "status": {"type": "string"}, "agent_type": {"type": "string"}, "depends_on": {"type": "array", "items": {"type": "string"}}, "conflict_domain": {"type": "string"}, "preferred_worker": {"type": "string"}, "required_worker": {"type": "string"}, "writable_files": {"type": "array", "items": {"type": "string"}}, "worker_prompt": {"type": "object"}, "created_at": {"type": "string", "format": "date-time"}, "lease_id": {"type": "string"}, "lease_metadata": {"type": "object"}, "failure_history": {"type": "array", "items": {"type": "object"}}, "completion_receipt": {"type": "object"}, "terminal_receipt": {"type": "object"}}},
    "staff_model": {"type": "object", "additionalProperties": false, "required": ["staff"], "properties": {"staff": {"type": "object", "additionalProperties": {"$ref": "#/$defs/worker_profile"}}}},
    "worker_profile": {"type": "object", "additionalProperties": false, "required": ["can_execute_tasks", "allowed_agent_types", "allowed_task_kinds", "required_metadata_by_kind"], "properties": {"can_execute_tasks": {"type": "boolean"}, "allowed_agent_types": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "allowed_task_kinds": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "required_metadata_by_kind": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string", "minLength": 1}}}}},
    "history": {"type": "object", "additionalProperties": false, "required": ["event_id", "event_type", "occurred_at", "project_id", "task_id", "change_summary"], "properties": {"event_id": {"type": "string", "minLength": 1}, "event_type": {"enum": ["published", "publish_updated"]}, "occurred_at": {"type": "string", "format": "date-time"}, "project_id": {"type": "string"}, "task_id": {"type": "string"}, "change_summary": {"type": "object"}}},
    "review_decision": {"type": "object", "additionalProperties": false, "required": ["event_id", "event_type", "occurred_at", "task_id", "reviewer", "verdict", "summary", "supersedes"], "properties": {"event_id": {"type": "string", "minLength": 1}, "event_type": {"const": "review_correction"}, "occurred_at": {"type": "string", "format": "date-time"}, "task_id": {"type": "string", "minLength": 1}, "reviewer": {"type": "string", "minLength": 1}, "verdict": {"enum": ["pass", "hold"]}, "summary": {"type": "string", "minLength": 1}, "supersedes": {"oneOf": [{"type": "object", "additionalProperties": false, "required": ["kind", "summary", "terminal_status"], "properties": {"kind": {"const": "terminal_summary"}, "summary": {}, "terminal_status": {"enum": ["done", "blocked", "failed"]}}}, {"type": "object", "additionalProperties": false, "required": ["kind", "event_id"], "properties": {"kind": {"const": "review_decision"}, "event_id": {"type": "string", "minLength": 1}}}]}}}
  }
}
